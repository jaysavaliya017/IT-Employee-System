{
  "name": "proattend-server",
  "version": "1.0.0",
  "description": "ProAttend IT Company Attendance & Leave Management System - Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run db:generate && npm run db:deploy && npm run db:seed",
    "db:reset": "prisma migrate reset --force --skip-seed && npm run db:seed",
    "db:reinit:supabase": "powershell -ExecutionPolicy Bypass -File ./scripts/reinit-supabase.ps1",
    "db:reinit:supabase:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/reinit-supabase.ps1 -Reset"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.24",
    "@types/pdfkit": "^0.13.9",
    "@types/uuid": "^9.0.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.14.0",
    "prisma": "^5.22.0",
    "socket.io": "^4.8.3",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {}
}